				float eros79 = input.ase_texcoord7.w;
				float smoothstepResult110 = smoothstep( eros79 , ( eros79 + _LUTErosionSmoothness ) , tex2DNode24.g);
				float2 temp_cast_1 = (( ( saturate( smoothstepResult110 ) * _LUTAmplitude ) + _LUTOffset )).xx;
