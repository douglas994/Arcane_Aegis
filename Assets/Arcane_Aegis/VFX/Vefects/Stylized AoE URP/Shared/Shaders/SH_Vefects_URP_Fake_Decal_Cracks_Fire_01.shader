				float cos52 = cos( ( ( ( _DecalRotation + randomRotate57 ) * ( 2.0 * PI ) ) / 360.0 ) );
				float sin52 = sin( ( ( ( _DecalRotation + randomRotate57 ) * ( 2.0 * PI ) ) / 360.0 ) );
				float2 rotator52 = mul( ( ( ( texCoord349 - _Vector1 ) / ( _DecalScaleFromCenterNonUniform * _DecalScaleFromCenter ) ) + _Vector1 ) - float2( 0.5,0.5 ) , float2x2( cos52 , -sin52 , sin52 , cos52 )) + float2( 0.5,0.5 );
